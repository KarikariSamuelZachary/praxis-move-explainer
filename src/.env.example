DB_NAME=praxis
DB_USER=praxis_user
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Upstash Redis (REST) — used by the backend rate limiter (src/core/rate_limit.py).
# The frontend reads these same two names (see frontend/src/lib/redis.ts).
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here